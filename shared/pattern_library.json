      ],
      "component_indicators": [
        {
          "pattern": "^\\d+\\.\\d+\\s+",
          "type": "hierarchy",
          "description": "Dotted numbering for hierarchy"
        }
      ],
      "quantity_rule": "inherit_from_parent"
